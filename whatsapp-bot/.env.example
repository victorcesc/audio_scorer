# URL da API do Audio Scorer (Railway ou local)
AUDIO_SCORER_API_URL=https://audioscorer-production.up.railway.app

# Token secreto: deve ser igual ao AUDIO_SCORER_BOT_TOKEN configurado na API (Railway / .env.local)
# Gere uma string aleatória longa (ex.: openssl rand -hex 32)
AUDIO_SCORER_BOT_TOKEN=seu_token_secreto_aqui

# Opcional (Railway + volume persistente): caminho absoluto onde a sessão WhatsApp fica guardada entre deploys.
# Ex.: monte um volume em /data e use WWEBJS_DATA_PATH=/data/wwebjs_auth
# WWEBJS_DATA_PATH=/data/wwebjs_auth
